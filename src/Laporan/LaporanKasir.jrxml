	<queryString language="SQL">
		<![CDATA[SELECT
     kasir.`id_kasir` AS kasir_id_kasir,
     kasir.`id_registrasi` AS kasir_id_registrasi,
     kasir.`id_pasien` AS kasir_id_pasien,
     kasir.`id_rawat_inap` AS kasir_id_rawat_inap,
     kasir.`biaya_dokter` AS kasir_biaya_dokter,
     kasir.`biaya_obat` AS kasir_biaya_obat,
     kasir.`id_resep` AS kasir_id_resep,
     kasir.`biaya_kamar` AS kasir_biaya_kamar,
     kasir.`total_bayar` AS kasir_total_bayar,
     kasir.`metode_pembayaran` AS kasir_metode_pembayaran,
     kasir.`id_rekam_medis` AS kasir_id_rekam_medis,
     kasir.`nama_pasien` AS kasir_nama_pasien
FROM
     `kasir` kasir]]>
	</queryString>
