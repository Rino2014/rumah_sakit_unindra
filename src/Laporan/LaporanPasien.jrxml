	<queryString language="SQL">
		<![CDATA[SELECT
     pendaftaran_pasien.`id_registrasi` AS pendaftaran_pasien_id_registrasi,
     pendaftaran_pasien.`tanggal_kunjungan` AS pendaftaran_pasien_tanggal_kunjungan,
     pendaftaran_pasien.`id_pasien` AS pendaftaran_pasien_id_pasien,
     pendaftaran_pasien.`nama_pasien` AS pendaftaran_pasien_nama_pasien,
     pendaftaran_pasien.`tempat_lahir` AS pendaftaran_pasien_tempat_lahir,
     pendaftaran_pasien.`tanggal_lahir` AS pendaftaran_pasien_tanggal_lahir,
     pendaftaran_pasien.`jenis_kelamin` AS pendaftaran_pasien_jenis_kelamin,
     pendaftaran_pasien.`no_telepon` AS pendaftaran_pasien_no_telepon,
     pendaftaran_pasien.`alamat` AS pendaftaran_pasien_alamat,
     pendaftaran_pasien.`poli` AS pendaftaran_pasien_poli,
     pendaftaran_pasien.`id_dokter` AS pendaftaran_pasien_id_dokter,
     pendaftaran_pasien.`nama_dokter` AS pendaftaran_pasien_nama_dokter,
     pendaftaran_pasien.`jenis_pembayaran` AS pendaftaran_pasien_jenis_pembayaran,
     pendaftaran_pasien.`keluhan_awal` AS pendaftaran_pasien_keluhan_awal
FROM
     `pendaftaran_pasien` pendaftaran_pasien]]>
	</queryString>
