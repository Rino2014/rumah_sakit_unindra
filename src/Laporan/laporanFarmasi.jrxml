	<queryString language="SQL">
		<![CDATA[SELECT
     farmasi.`id_resep` AS farmasi_id_resep,
     farmasi.`id_registrasi` AS farmasi_id_registrasi,
     farmasi.`nama_pasien` AS farmasi_nama_pasien,
     farmasi.`diskon` AS farmasi_diskon,
     farmasi.`total_bayar` AS farmasi_total_bayar,
     farmasi.`metode_pembayaran` AS farmasi_metode_pembayaran,
     farmasi.`tanggal_resep` AS farmasi_tanggal_resep,
     farmasi.`obat1` AS farmasi_obat1,
     farmasi.`obat2` AS farmasi_obat2,
     farmasi.`obat3` AS farmasi_obat3,
     farmasi.`obat4` AS farmasi_obat4,
     farmasi.`id_rekam_medis` AS farmasi_id_rekam_medis,
     farmasi.`subtotal1` AS farmasi_subtotal1,
     farmasi.`subtotal2` AS farmasi_subtotal2,
     farmasi.`subtotal3` AS farmasi_subtotal3,
     farmasi.`subtotal4` AS farmasi_subtotal4
FROM
     `farmasi` farmasi]]>
	</queryString>
