	<queryString language="SQL">
		<![CDATA[SELECT
     pemeriksaan_dokter.`id_rekam_medis` AS pemeriksaan_dokter_id_rekam_medis,
     pemeriksaan_dokter.`id_registrasi` AS pemeriksaan_dokter_id_registrasi,
     pemeriksaan_dokter.`id_pasien` AS pemeriksaan_dokter_id_pasien,
     pemeriksaan_dokter.`id_dokter` AS pemeriksaan_dokter_id_dokter,
     pemeriksaan_dokter.`nama_dokter` AS pemeriksaan_dokter_nama_dokter,
     pemeriksaan_dokter.`nama_pasien` AS pemeriksaan_dokter_nama_pasien,
     pemeriksaan_dokter.`poli` AS pemeriksaan_dokter_poli,
     pemeriksaan_dokter.`keluhan_awal` AS pemeriksaan_dokter_keluhan_awal,
     pemeriksaan_dokter.`diagnosa` AS pemeriksaan_dokter_diagnosa,
     pemeriksaan_dokter.`tekanan_darah` AS pemeriksaan_dokter_tekanan_darah,
     pemeriksaan_dokter.`suhu_tubuh` AS pemeriksaan_dokter_suhu_tubuh,
     pemeriksaan_dokter.`berat_badan` AS pemeriksaan_dokter_berat_badan,
     pemeriksaan_dokter.`golongan_darah` AS pemeriksaan_dokter_golongan_darah,
     pemeriksaan_dokter.`tindakan_medis` AS pemeriksaan_dokter_tindakan_medis,
     pemeriksaan_dokter.`resep_obat` AS pemeriksaan_dokter_resep_obat,
     pemeriksaan_dokter.`biaya_dokter` AS pemeriksaan_dokter_biaya_dokter,
     pemeriksaan_dokter.`catatan_dokter` AS pemeriksaan_dokter_catatan_dokter
FROM
     `pemeriksaan_dokter` pemeriksaan_dokter]]>
	</queryString>
